class Solution {
public:
    int finding(int  a, int n,vector<int>& dp){
        if(a==n) return 1;
        if(a>n) return 0;
        if(dp[a]!=-1) return dp[a];
        int step1 = finding(a+2,n,dp);
        int step2 = finding(a+1,n,dp);
        return dp[a]=step1+step2;
    }
    int climbStairs(int n) {
       vector<int>dp(n+1,-1);
       return finding(0,n,dp); 
    }
};
