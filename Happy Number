class Solution {
    int next(int n){
        int result = 0;
        while(n>0){
            int last = n%10;
            result += last*last;
            n/=10;
        }
        return result;
    }
public:
    bool isHappy(int n) {
        unordered_set<int>seen;
        while(n!=1 && seen.find(n)==seen.end()){
            seen.insert(n);
            n=next(n);
        }
        return n==1;
    }
};
